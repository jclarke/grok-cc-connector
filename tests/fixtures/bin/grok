#!/usr/bin/env node
// Fake `grok` CLI for broker and companion smoke tests.
// Handles --version, agent --help, and `agent stdio` ACP JSON-RPC.
"use strict";

const readline = require("readline");

const args = process.argv.slice(2);

function hasFlag(flag) {
  return args.includes(flag);
}

if (hasFlag("--version")) {
  process.stdout.write("fake-grok 0.0.0-smoke\n");
  process.exit(0);
}

if (args[0] === "agent" && hasFlag("--help")) {
  process.stdout.write("fake grok agent\n");
  process.exit(0);
}

const isAgentStdio =
  args.includes("stdio") &&
  (args[0] === "agent" || (args[0] === "--no-auto-update" && args[1] === "agent"));

if (!isAgentStdio) {
  process.stderr.write(`fake-grok: unsupported invocation: ${args.join(" ")}\n`);
  process.exit(1);
}

const rl = readline.createInterface({ input: process.stdin });

rl.on("line", (line) => {
  const trimmed = line.trim();
  if (!trimmed) {
    return;
  }

  let message;
  try {
    message = JSON.parse(trimmed);
  } catch {
    return;
  }

  if (message.id === undefined || !message.method) {
    return;
  }

  let result = {};
  if (message.method === "initialize") {
    result = {
      protocolVersion: 1,
      authMethods: [{ id: "cached_token" }],
      serverInfo: { name: "fake-grok" }
    };
  } else if (message.method === "authenticate") {
    result = {};
  } else {
    result = { ok: true };
  }

  process.stdout.write(`${JSON.stringify({ jsonrpc: "2.0", id: message.id, result })}\n`);
});

process.stdin.resume();